{
  "name": "node_express_toolkit",
  "version": "2.0.0",
  "description": "starter kit for node aplications in express and typescript",
  "keywords": [
    "express",
    "nodejs",
    "typescript",
    "jest"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akavishwa19/node-express-toolkit"
  },
  "bugs": {
    "url": "https://github.com/akavishwa19/node-express-toolkit/issues"
  },
  "author": "Akash Vishwakarma <akash19102001@gmail.com> (https://www.akashvishwakarma.com)",
  "license": "MIT",
  "type": "commonjs",
  "main": "src/app",
  "scripts": {
    "format": "prettier --log-level=silent --write .",
    "format:check": "prettier --log-level=silent --check .",
    "clean": "rm -rf dist",
    "build": "tsc --project tsconfig.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint --fix src tests",
    "dev": "nodemon",
    "start:dev": "node dist/app.js",
    "start": "npm run clean && npm run build && npm run start:dev",
    "preversion": "npm run lint && npm run test",
    "version:write": "node src/scripts/versionUpdate.mjs && npm run lint:fix",
    "version": "echo $npm_package_version",
    "prepare": "husky",
    "changelog:write": "node src/scripts/updateChangelog.mjs",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:up:build": "docker compose up -d --build",
    "docker:recreate": "npm run docker:down && npm run docker:up:build"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "mysql2": "^3.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "simple-git": "^3.31.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=24"
  }
}
